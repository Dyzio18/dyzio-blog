{
  "name": "dyzio-blog",
  "version": "1.0.1",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "content:assets": "node ./scripts/generate-content-assets.mjs",
    "start": "next start",
    "dev": "pnpm content:assets && next dev",
    "build": "pnpm content:assets && next build && node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "pnpm content:assets && ANALYZE=true next build",
    "lint": "eslint app components layouts scripts data next.config.js tailwind.config.js postcss.config.js prettier.config.js eslint.config.mjs"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@next/bundle-analyzer": "16.2.5",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.22",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "image-size": "2.0.2",
    "katex": "^0.16.11",
    "leaflet": "^1.9.4",
    "next": "16.2.5",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-leaflet": "^5.0.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.1",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "^2.0.1",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@opentelemetry/api": "1.4.1",
    "@opentelemetry/core": "1.13.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.39.1",
    "@opentelemetry/resources": "1.13.0",
    "@opentelemetry/sdk-trace-base": "1.13.0",
    "@opentelemetry/sdk-trace-node": "1.13.0",
    "@opentelemetry/semantic-conventions": "1.13.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  }
}